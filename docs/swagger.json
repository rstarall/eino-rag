{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "基于Eino框架的RAG(检索增强生成)系统API\n支持文档上传、向量化索引、语义搜索等功能",
        "title": "Eino RAG API",
        "termsOfService": "http://www.github.com/rstarall",
        "contact": {
            "name": "API Support",
            "url": "http://www.github.com/rstarall",
            "email": "http://www.github.com/rstarall"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/health": {
            "get": {
                "description": "检查服务运行状态",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统"
                ],
                "summary": "健康检查",
                "responses": {
                    "200": {
                        "description": "服务正常",
                        "schema": {
                            "$ref": "#/definitions/handlers.HealthResponse"
                        }
                    }
                }
            }
        },
        "/api/search": {
            "post": {
                "description": "根据查询内容在已索引的文档中进行语义搜索",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "搜索"
                ],
                "summary": "搜索文档",
                "parameters": [
                    {
                        "description": "搜索请求参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.SearchRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "搜索成功",
                        "schema": {
                            "$ref": "#/definitions/handlers.SearchResponse"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "搜索服务错误",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/stats": {
            "get": {
                "description": "获取文档处理和索引的统计信息",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统"
                ],
                "summary": "获取处理统计",
                "responses": {
                    "200": {
                        "description": "获取统计信息成功",
                        "schema": {
                            "$ref": "#/definitions/handlers.ProcessingStatsResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/upload": {
            "post": {
                "description": "上传PDF、Word、TXT等格式的文档进行向量化处理和索引",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "文档管理"
                ],
                "summary": "上传文档",
                "parameters": [
                    {
                        "type": "file",
                        "description": "文档文件 (支持 .pdf, .docx, .txt 格式)",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "文档元数据 (JSON格式)",
                        "name": "metadata",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "上传成功",
                        "schema": {
                            "$ref": "#/definitions/handlers.UploadResponse"
                        }
                    },
                    "400": {
                        "description": "请求错误 (文件格式不支持、文件过大等)",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "413": {
                        "description": "文件过大",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.DocResult": {
            "type": "object",
            "properties": {
                "content": {
                    "description": "文档内容",
                    "type": "string",
                    "example": "这是文档的内容片段..."
                },
                "id": {
                    "description": "文档ID",
                    "type": "string",
                    "example": "doc_12345"
                },
                "metadata": {
                    "description": "文档元数据",
                    "type": "object",
                    "additionalProperties": true
                },
                "score": {
                    "description": "相似度分数",
                    "type": "number",
                    "example": 0.85
                }
            }
        },
        "handlers.ErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "description": "错误信息",
                    "type": "string",
                    "example": "操作失败的原因"
                },
                "success": {
                    "description": "操作是否成功",
                    "type": "boolean",
                    "example": false
                }
            }
        },
        "handlers.HealthResponse": {
            "type": "object",
            "properties": {
                "service": {
                    "description": "服务名称",
                    "type": "string",
                    "example": "eino-rag"
                },
                "status": {
                    "description": "服务状态",
                    "type": "string",
                    "example": "healthy"
                },
                "timestamp": {
                    "description": "时间戳",
                    "type": "integer",
                    "example": 1640995200
                }
            }
        },
        "handlers.ProcessingStatsResponse": {
            "type": "object",
            "properties": {
                "stats": {
                    "description": "统计信息"
                },
                "success": {
                    "description": "操作是否成功",
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "handlers.SearchRequest": {
            "type": "object",
            "required": [
                "query"
            ],
            "properties": {
                "query": {
                    "description": "搜索查询内容",
                    "type": "string",
                    "example": "人工智能的发展历史"
                },
                "return_context": {
                    "description": "是否返回上下文信息",
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "handlers.SearchResponse": {
            "type": "object",
            "properties": {
                "context": {
                    "description": "生成的上下文信息",
                    "type": "string",
                    "example": "根据检索到的文档..."
                },
                "documents": {
                    "description": "检索到的文档列表",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handlers.DocResult"
                    }
                },
                "query": {
                    "description": "原始查询内容",
                    "type": "string",
                    "example": "人工智能的发展历史"
                },
                "success": {
                    "description": "操作是否成功",
                    "type": "boolean",
                    "example": true
                },
                "timestamp": {
                    "description": "响应时间戳",
                    "type": "integer",
                    "example": 1640995200
                }
            }
        },
        "handlers.UploadResponse": {
            "type": "object",
            "properties": {
                "chunk_count": {
                    "description": "文档分块数量",
                    "type": "integer",
                    "example": 5
                },
                "message": {
                    "description": "响应消息",
                    "type": "string",
                    "example": "Document indexed successfully"
                },
                "success": {
                    "description": "操作是否成功",
                    "type": "boolean",
                    "example": true
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "description": "Bearer token authentication",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}