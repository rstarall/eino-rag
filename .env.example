# Eino RAG 系统环境变量配置示例
# 复制此文件为 .env 并根据你的环境修改配置值

# ==================== Milvus 向量数据库配置 ====================
# Milvus 服务器地址
MILVUS_HOST=localhost
# Milvus 服务器端口
MILVUS_PORT=19530
# 向量集合名称
COLLECTION_NAME=rag_documents_bge_m3
# 向量维度（需要与嵌入模型匹配）
VECTOR_DIM=1024
# 距离计算方法 (L2, IP, COSINE)
METRIC_TYPE=L2
# 索引类型
INDEX_TYPE=IVF_FLAT

# ==================== Ollama 配置 ====================
# Ollama 服务地址
OLLAMA_URL=http://localhost:11434
# 嵌入模型名称
EMBEDDING_MODEL=bge-m3
# 大语言模型名称（用于对话生成）
LLM_MODEL=gpt-4o

# ==================== OpenAI 配置 ====================
# OpenAI API 密钥（如果使用OpenAI进行对话生成）
OPENAI_API_KEY=your-openai-api-key-here
# OpenAI 模型名称
OPENAI_MODEL=gpt-4o
# OpenAI API 基础URL（可选，用于代理或自定义端点）
OPENAI_BASE_URL=

# ==================== RAG 系统配置 ====================
# 文档最小分块大小（字符数，用于语义分割）
CHUNK_SIZE=800
# 分块重叠大小（已废弃，保留向后兼容）
CHUNK_OVERLAP=50
# 检索返回的相关文档数量
TOP_K=5
# 相似度阈值（0.0-1.0）
SCORE_THRESHOLD=0.7
# 是否启用语义分割（true/false）
# 注：小于 CHUNK_SIZE 字符的文档会自动使用传统分块
SEMANTIC_SPLITTING=true
# 是否启用嵌入缓存（true/false）
EMBEDDING_CACHE=true

# ==================== 服务器配置 ====================
# 服务器端口
SERVER_PORT=8080
# 最大上传文件大小（字节）
MAX_UPLOAD_SIZE=10485760

# ==================== 开发环境配置 ====================
# Gin 运行模式 (debug, release, test)
GIN_MODE=debug

# ==================== Docker 环境配置 ====================
# 以下配置用于 Docker 部署时的内部服务发现
# MILVUS_HOST=milvus-standalone
# OLLAMA_URL=http://ollama:11434

# ==================== 日志配置 ====================
# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
# 日志格式 (json, console)
LOG_FORMAT=console

# ==================== 缓存配置 ====================
# Redis 配置（如果使用缓存）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ==================== 安全配置 ====================
# API 密钥（如果需要）
# API_KEY=your-api-key-here
# JWT 密钥（如果使用JWT）
# JWT_SECRET=your-jwt-secret-here

# ==================== 监控配置 ====================
# 是否启用 Prometheus 监控
# ENABLE_METRICS=true
# 监控端口
# METRICS_PORT=9090

# ==================== 其他配置 ====================
# 是否启用调试模式
DEBUG=false
# 请求超时时间（秒）
REQUEST_TIMEOUT=30
